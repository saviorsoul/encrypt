{
  "name": "encrypt",
  "version": "0.3.2",
  "private": true,
  "homepage": "https://saviorsoul.github.io/encrypt",
  "bugs": "https://github.com/saviorsoul/encrypt/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/saviorsoul/encrypt"
  },
  "author": "saviorsoul <artur.banka@gmail.com> (https://github.com/saviorsoul)",
  "license": "MIT",
  "keywords": [
    "encrypt",
    "encryption",
    "cryptography"
  ],
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "npm run dev -w @encrypt/web",
    "start": "npm run start -w @encrypt/web",
    "build": "npm run build -w @encrypt/web",
    "build:pages": "npm run build:pages -w @encrypt/web",
    "preview": "npm run preview -w @encrypt/web",
    "electron:dev": "npm run electron:dev -w @encrypt/web",
    "electron:preview": "npm run electron:preview -w @encrypt/web",
    "electron:run": "npm run electron:run -w @encrypt/web",
    "electron:build": "npm run electron:build -w @encrypt/web",
    "electron:package": "npm run electron:package -w @encrypt/web",
    "test": "npm run test -w @encrypt/web -- run && npm run test -w @encrypt/api",
    "lint": "eslint apps/web apps/api apps/feed-lab packages/core packages/schemas",
    "lint:fix": "eslint apps/web apps/api apps/feed-lab packages/core packages/schemas --fix",
    "format": "prettier --write apps/web apps/api apps/feed-lab packages/core packages/schemas",
    "format:check": "prettier --check apps/web apps/api apps/feed-lab packages/core packages/schemas",
    "dev:api": "npm run dev -w @encrypt/api",
    "dev:lab": "npm run dev -w @encrypt/feed-lab",
    "dev:stack": "docker compose --env-file .env.docker up -d",
    "dev:stack:build": "docker compose --env-file .env.docker up -d --build",
    "dev:stack:logs": "docker compose --env-file .env.docker logs -f",
    "docker:down": "docker compose --env-file .env.docker down",
    "db:migrate": "npm run migrate -w @encrypt/api",
    "db:citus:distribute": "npm run db:citus:distribute -w @encrypt/api",
    "db:seed": "npm run db:seed -w @encrypt/api",
    "db:setup": "npm run db:setup -w @encrypt/api",
    "postinstall": "npm run postinstall -w @encrypt/api --if-present"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "typescript-eslint": "^8.61.0"
  }
}
