{
  "name": "@encrypt/api",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:docker": "prisma generate && tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "postinstall": "prisma generate",
    "migrate": "tsx scripts/run-with-env.ts prisma migrate deploy",
    "migrate:dev": "tsx scripts/run-with-env.ts prisma migrate dev",
    "db:citus:distribute": "tsx scripts/citus-distribute.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "npm run migrate && npm run db:citus:distribute",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@encrypt/core": "*",
    "@koa/router": "^13.1.0",
    "@prisma/client": "^6.19.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "dotenv": "^16.4.5",
    "koa": "^3.0.0",
    "koa-bodyparser": "^4.4.1",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "redis": "^5.8.2"
  },
  "devDependencies": {
    "prisma": "^6.19.0",
    "@types/pg": "^8.15.5",
    "@types/koa": "^2.15.0",
    "@types/koa__router": "^12.0.4",
    "@types/koa-bodyparser": "^4.3.12",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
