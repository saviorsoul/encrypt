# Copy to .env for local development (repo root):
#   cp .env.example .env
#
# Docker Compose uses .env.docker
# Electron builds use .env.electron

# --- Citus / Docker ---
POSTGRES_USER=encrypt
POSTGRES_PASSWORD=encrypt
POSTGRES_DB=encrypt_feed
POSTGRES_PORT=5432

# --- API ---
PORT=3000
LOG_LEVEL=info
DATABASE_URL=postgresql://encrypt:encrypt@localhost:5432/encrypt_feed
REDIS_URL=redis://localhost:6379

# Multiple origins: comma-separated (spaces around commas are trimmed).
# CORS_ALLOWED_ORIGINS=https://project-ef3884e2-07da-4a36-9eb-feed-lab.storage.googleapis.com,http://localhost:5174

# --- feed-lab / web (Vite; only VITE_* is exposed to the client) ---
# Leave unset (or empty) in dev so feed-lab uses the Vite proxy and can read X-Next-Nonce.
# VITE_API_URL=http://localhost:3000
VITE_PROXY_TARGET=http://localhost:3000
