generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  keyId     String   @id
  publicKey Json
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

model Message {
  id        String   @id @db.Uuid
  payload   String
  createdAt DateTime @default(now()) @map("created_at")

  shares   Share[]
  comments Comment[]

  @@map("messages")
}

model Share {
  id        String   @id @db.Uuid
  messageId String   @map("message_id") @db.Uuid
  payload   String
  createdAt DateTime @default(now()) @map("created_at")

  threadRoot Message @relation(fields: [messageId], references: [id], onDelete: Restrict)

  @@index([messageId])
  @@map("shares")
}

model Comment {
  id        String   @id @db.Uuid
  messageId String   @map("message_id") @db.Uuid
  payload   String
  createdAt DateTime @default(now()) @map("created_at")

  threadRoot Message @relation(fields: [messageId], references: [id], onDelete: Restrict)

  @@index([messageId])
  @@map("comments")
}

model MessageKeyManifestShard {
  messageId      String  @map("message_id") @db.Uuid // thread root message id
  recipientKeyId String  @map("recipient_key_id") // Citus distribution key; must exist in users (app-enforced; no DB FK — Citus limitation)
  shareId        String? @map("share_id") @db.Uuid // null = original message shard; set = share delivery shard
  entryJson      String  @map("entry_json")

  @@id([messageId, recipientKeyId])
  @@index([recipientKeyId])
  @@index([shareId])
  @@map("message_key_manifest_shards")
}

model FriendshipRequest {
  requesterKeyId String   @map("requester_key_id")
  targetKeyId    String   @map("target_key_id")
  status         String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@id([requesterKeyId, targetKeyId])
  @@index([targetKeyId, status])
  @@map("friendship_requests")
}

model UserFriendship {
  ownerKeyId  String   @map("owner_key_id")
  friendKeyId String   @map("friend_key_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@id([ownerKeyId, friendKeyId])
  @@map("user_friendships")
}
