{
  "name": "encrypt",
  "version": "0.1.6",
  "private": true,
  "homepage": "https://saviorsoul.github.io/encrypt",
  "bugs": "https://github.com/saviorsoul/encrypt/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/saviorsoul/encrypt"
  },
  "author": "saviorsoul <artur.banka@gmail.com> (https://github.com/saviorsoul)",
  "license": "MIT",
  "keywords": [
    "encrypt",
    "encryption",
    "cryptography"
  ],
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "npm run dev -w @encrypt/web",
    "start": "npm run start -w @encrypt/web",
    "build": "npm run build -w @encrypt/web",
    "build:pages": "npm run build:pages -w @encrypt/web",
    "preview": "npm run preview -w @encrypt/web",
    "electron:dev": "npm run electron:dev -w @encrypt/web",
    "electron:preview": "npm run electron:preview -w @encrypt/web",
    "electron:run": "npm run electron:run -w @encrypt/web",
    "electron:build": "npm run electron:build -w @encrypt/web",
    "test": "npm run test -w @encrypt/web",
    "lint": "eslint apps/web apps/api packages/schemas",
    "lint:fix": "eslint apps/web apps/api packages/schemas --fix",
    "format": "prettier --write apps/web apps/api packages/schemas",
    "format:check": "prettier --check apps/web apps/api packages/schemas",
    "dev:api": "npm run dev -w @encrypt/api",
    "dev:stack": "docker compose up -d && npm run dev:api",
    "db:migrate": "npm run migrate -w @encrypt/api"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "typescript-eslint": "^8.61.0"
  }
}
