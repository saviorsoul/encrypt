{
  "name": "encrypt",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://saviorsoul.github.io/encrypt",
  "bugs": "https://github.com/saviorsoul/encrypt/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/saviorsoul/encrypt"
  },
  "author": "saviorsoul <artur.banka@gmail.com> (https://github.com/saviorsoul)",
  "license": "MIT",
  "keywords": [
    "encrypt",
    "encryption",
    "cryptography"
  ],
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^6.30.3",
    "web-vitals": "^2.1.4"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "tsc --noEmit && vite build",
    "build:pages": "tsc --noEmit && GITHUB_PAGES=true vite build && cp dist/index.html dist/404.html",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite --mode electron\" \"wait-on http://localhost:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 electron . --no-sandbox\"",
    "electron:preview": "vite build --mode electron && electron . --no-sandbox",
    "electron:build": "vite build --mode electron && electron-builder",
    "test": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "build": {
    "appId": "com.encrypt.app",
    "productName": "Encrypt",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.utilities"
    }
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12",
    "wait-on": "^8.0.3",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.15.21",
    "@vitejs/plugin-react": "^4.5.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.8.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.3.5",
    "vitest": "^3.2.1"
  }
}
